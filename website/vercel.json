{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/netbox",
      "dest": "/scripts/netbox_setup.sh"
    },
    {
      "src": "/justswapit",
      "dest": "/scripts/justswapit.sh"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}